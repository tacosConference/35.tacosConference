		"@types/bootstrap": "^5.2.11",
		"@types/node": "^24.13.2",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^16.5.0",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^3.5.2",
